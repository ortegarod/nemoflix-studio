{
  "id": "sdxl_img2img",
  "name": "SDXL Image-to-Image",
  "description": "Generate SDXL image variations from a source image using prompt guidance and denoise strength",
  "task": "image-to-image",
  "output_type": "image",
  "requirements": {
    "vram_gb": 8,
    "workflow_type": "sdxl",
    "supports_lora": false
  },
  "params": {
    "prompt": {"type": "string", "required": true, "description": "Image prompt / transformation guidance"},
    "image": {"type": "string", "required": true, "description": "Source image filename or Studio output path"},
    "negative_prompt": {"type": "string", "default": ""},
    "width": {"type": "integer", "default": 832},
    "height": {"type": "integer", "default": 1216},
    "seed": {"type": "integer", "default": 42},
    "steps": {"type": "integer", "default": 28},
    "cfg": {"type": "float", "default": 7.0},
    "sampler": {"type": "string", "default": "dpmpp_2m"},
    "scheduler": {"type": "string", "default": "karras"},
    "denoise": {"type": "float", "default": 0.35, "description": "Lower preserves the source image more; 0.25-0.45 is good for identity-preserving variations"},
    "checkpoint": {"type": "string", "required": true, "description": "SDXL checkpoint model filename"}
  },
  "compatible_providers": ["local"],
  "examples": [
    {
      "prompt": "landscape photo restyled as an oil painting, soft golden light",
      "image": "images/source.png",
      "checkpoint": "your-sdxl-checkpoint.safetensors",
      "denoise": 0.35
    }
  ]
}
